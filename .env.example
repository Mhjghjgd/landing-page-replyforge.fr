# ============================================================
# ReplyForge — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs.
# ============================================================

# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# === APP ===
# URL publique (https://replyforge.fr en prod, http://localhost:3000 en dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === STRIPE (Phase 2) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# IDs des produits Stripe (récupérés dans Stripe Dashboard → Products)
STRIPE_PRICE_SUBSCRIPTION=       # price_xxx — abonnement 89 €/mois
STRIPE_PRICE_CATCHUP=            # price_xxx — rattrapage one-shot (Phase 6)

# === ZERNIO (Phase 4) ===
ZERNIO_API_KEY=sk_
ZERNIO_API_URL=https://zernio.com/api/v1
ZERNIO_WEBHOOK_SECRET=

# === ANTHROPIC / CLAUDE API (Phase 5) ===
ANTHROPIC_API_KEY=

# === RESEND (emails transactionnels) ===
RESEND_API_KEY=
